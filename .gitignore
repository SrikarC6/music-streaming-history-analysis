# ══════════════════════════════════════════════════════════════════════════════
# Python
# ══════════════════════════════════════════════════════════════════════════════

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.env
.venv
env/
venv/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# pyenv
.python-version

# mypy / type checkers
.mypy_cache/
.dmypy.json
.pyre/

# dotenv secrets
.env
.env.*

# ══════════════════════════════════════════════════════════════════════════════
# R
# ══════════════════════════════════════════════════════════════════════════════

# History and session data
.Rhistory
.Rapp.history
.RData
.Ruserdata

# RStudio project files
*.Rproj.user/
.Rproj.user

# R Markdown / Quarto outputs (keep .Rmd/.qmd sources, ignore renders)
*.html
*.pdf
*.docx                  # Word output from knit
*_files/                # figures and dependencies folder (e.g. report_files/)
*_cache/                # knitr chunk cache (e.g. report_cache/)
figure-html/            # ggplot figure output
figure-latex/
figure-gfm/

# Quarto
.quarto/
_site/                  # rendered site output
_book/                  # rendered book output
_freeze/                # Quarto freeze cache

# RPubs / shinyapps.io deployment metadata
rsconnect/

# Packrat / renv dependency management
packrat/lib/
packrat/src/
renv/library/
renv/staging/
.Rprofile   # often auto-generated by renv

# knitr
knitr_figures/

# ══════════════════════════════════════════════════════════════════════════════
# Project-specific (Spotify/Last.fm data files)
# ══════════════════════════════════════════════════════════════════════════════

# Raw exported data — keep out of version control (large + personal)
Streaming_History_Audio_*.json
apple-music-library-tracks.json
apple-music-play-activity.csv
listening-history-clean.csv

# Manim / Manim Slides generated media / Other related Manim assets
**/media/
**/partial_movie_files/
**/slides/files/
**/media/**/*.json
**/slides/*.json
*.svg
presentation-stt-180_assets

# API keys / secrets (never commit these)
secrets.py
config.py
.secrets
*.key

# ══════════════════════════════════════════════════════════════════════════════
# OS
# ══════════════════════════════════════════════════════════════════════════════

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
desktop.ini

# Linux
*~
